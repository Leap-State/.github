status.\"\"\"\n","    products_list = [\n","        (\"Organic Milk\", \"Dairy\"), (\"Fresh Avocado\", \"Produce\"), \n","        (\"Greek Yogurt\", \"Dairy\"), (\"Sourdough Bread\", \"Bakery\"),\n","        (\"Almond Milk\", \"Beverages\"), (\"Red Apples\", \"Produce\"),\n","        (\"Dark Chocolate\", \"Snacks\"), (\"Avocado Toast Kit\", \"Bakery\")\n","    ]\n","    stores = [\"Corner Market\", \"Green Grocer\", \"City SuperMart\", \"Local Pantry\", \"Organic Hub\"]\n","    data = []\n","    today = datetime.date.today()\n","\n","    for _ in range(30):\n","        p_name, p_cat = random.choice(products_list)\n","        store = random.choice(stores)\n","        dist = round(random.uniform(0.5, 10.0), 1)\n","        qty = random.randint(5, 50)\n","        price = round(random.uniform(3.0, 15.0), 2)\n","        is_producer = random.choice([True, False])\n","        address = f\"{random.randint(10, 99)} Local Street, {store}\"\n","        \n","        # Expiry Logic: Mix of recent and future\n","        days_to_exp = random.randint(-2, 20)\n","        expiry = today + datetime.timedelta(days=days_to_exp)\n","            \n","        data.append({\n","            \"Product\": p_name, \"Category\": p_cat, \"Store_Name\": store,\n","            \"Distance_km\": dist, \"Stock_Qty\": qty, \"Expiry_Date\": expiry,\n","            \"Price\": price, \"Last_Updated\": today, \"Is_Producer\": is_producer,\n","            \"Address\": address\n","        })\n","    return pd.DataFrame(data)\n","\n","# Shared state\n","public_inventory = generate_initial_data()\n","\n","# ==========================================\n","# 2. AGENTIC ENGINE (The Information Broker)\n","# ==========================================\n","\n","class LogiflowAgent:\n","    def __init__(self, df):\n","        self.df = df\n","\n","    def search_and_format(self, query):\n","        \"\"\"USER SIDE: Generates a clean, text-centric search report.\"\"\"\n","        results = self.df[self.df['Product'].str.contains(query, case=False, na=False)]\n","        \n","        if results.empty or results['Stock_Qty'].sum() == 0:\n","            return \"⚠️ No local matches found. Try another product name.\"\n","\n","        html_output = \"<div style='font-family: sans-serif; line-height: 1.6;'>\"\n","        today = datetime.date.today()\n","        \n","        # Counter for Impact Summary\n","        donation_count = 0\n","        producer_count = 0\n","\n","        for _, row in results.iterrows():\n","            # 1. Producer Logic\n","            producer_text = \"🌿 DIRECT FROM LOCAL FARMER\" if row['Is_Producer'] else \"\"\n","            if row['Is_Producer']: producer_count += 1\n","            \n","            # 2. Donation Logic\n","            days_to_exp = (row['Expiry_Date'] - today).days\n","            is_donation = days_to_exp < 2\n","            \n","            if is_donation:\n","                donation_count += 1\n","                price_text = \"🎁 STATUS: AVAILABLE FOR DONATION / FREE\"\n","            else:\n","                price_text = f\"Price: ${row['Price']:.2f}\"\n","\n","            # 3. Build Result Block\n","            html_output += f\"\"\"\n","            <div style=\"border-bottom: 2px solid #eee; padding: 15px 0;\">\n","                <div style=\"font-size: 1.2em; font-weight: bold; color: #2c3e50;\">{row['Product']}</div>\n","                <div style=\"color: #27ae60; font-weight: bold; margin: 2px 0;\">{producer_text}</div>\n","                <div style=\"font-size: 1.1em; color: #e67e22; font-weight: bold;\">{price_text}</div>\n","                <div style=\"margin-top: 8px;\"><b>HOW TO FIND IT:</b> {row['Address']}</div>\n","                <div style=\"font-size: 0.9em; color: #7f8c8d; margin-top: 5px;\">📍 {row['Store_Name']} ({row['Distance_km']} km)</div>\n","                <div style=\"font-style: italic; color: #2980b9; font-size: 0.85em; margin-top: 5px;\">📍 Visit this local business to save this item from waste!</div>\n","            </div>\n","            \"\"\"\n","\n","        # 4. Impact Summary\n","        html_output += f\"\"\"\n","        <div style=\"margin-top: 30px; padding: 15px; background-color: #f9f9f9; border-radius: 8px; border-left: 5px solid #27ae60;\">\n","            <h4 style=\"margin: 0 0 10px 0;\">📊 Search Impact Summary:</h4>\n","            <p style=\"margin: 5px 0;\">• Items available for donation nearby: <b>{donation_count}</b></p>\n","            <p style=\"margin: 5px 0;\">• Products from local farmers: <b>{producer_count}</b></p>\n","        </div>\n","        \"\"\"\n","        html_output += \"</div>\"\n","        return html_output\n","\n","    def update_inventory(self, new_entry: dict):\n","        \"\"\"SELLER SIDE: Updates or adds new product entry.\"\"\"\n","        global public_inventory\n","        mask = (public_inventory['Product'] == new_entry['Product']) & \\\n","               (public_inventory['Store_Name'] == new_entry['Store_Name'])\n","        \n","        new_row = pd.DataFrame([new_entry])\n","        \n","        if not public_inventory[mask].empty:\n","            public_inventory.loc[mask, ['Stock_Qty', 'Price', 'Expiry_Date', 'Last_Updated', 'Is_Producer', 'Address']] = \\\n","                [new_entry['Stock_Qty'], new_entry['Price'], new_entry['Expiry_Date'], \n","                 new_entry['Last_Updated'], new_entry['Is_Producer'], new_entry['Address']]\n","            return \"✅ Stock Updated!\"\n","        else:\n","            public_inventory = pd.concat([public_inventory, new_row], ignore_index=True)\n","            return \"✅ New Product Broadcasted!\"\n","\n","# ==========================================\n","# 3. INTERACTIVE UI (The Bridge Dashboard)\n","# ==========================================\n","\n","agent = LogiflowAgent(public_inventory)\n","\n","# --- WIDGETS ---\n","user_search_input = widgets.Text(placeholder='e.g. Milk', description='🔍 Search:', layout=widgets.Layout(width='300px'))\n","user_search_btn = widgets.Button(description='Find Nearby', button_style='info', icon='search')\n","user_output = widgets.Output()\n","\n","s_prod = widgets.Text(description=\"Product:\", placeholder=\"Organic Milk\")\n","s_qty = widgets.IntText(description=\"Qty:\", value=10)\n","s_price = widgets.FloatText(description=\"Price ($):\", value=5.0)\n","s_exp = widgets.DatePicker(description=\"Expiry:\")\n","s_store = widgets.Text(description=\"Store Name:\", placeholder=\"Corner Market\")\n","s_addr = widgets.Text(description=\"Address:\", placeholder=\"123 Local Lane\")\n","s_is_prod = widgets.Checkbox(description=\"Local Producer?\", value=False)\n","s_submit = widgets.Button(description='Submit to Logiflow', button_style='success', icon='cloud-upload')\n","seller_output = widgets.Output()\n","\n","# --- EVENT HANDLERS ---\n","\n","def on_search_clicked(b):\n","    with user_output:\n","        clear_output()\n","        display(HTML(agent.search_and_format(user_search_input.value)))\n","\n","def on_seller_submit(b):\n","    with seller_output:\n","        clear_output()\n","        try:\n","            if not s_exp.value:\n","                print(\"❌ Please select an expiry date.\")\n","                return\n","\n","            new_entry = {\n","                \"Product\": s_prod.value,\n","                \"Category\": \"General\",\n","                \"Store_Name\": s_store.value,\n","                \"Distance_km\": round(random.uniform(0.1, 5.0), 1),\n","                \"Stock_Qty\": s_qty.value,\n","                \"Expiry_Date\": s_exp.value,\n","                \"Price\": s_price.value,\n","                \"Last_Updated\": datetime.datetime.now(),\n","                \"Is_Producer\": s_is_prod.value,\n","                \"Address\": s_addr.value\n","            }\n","\n","            msg = agent.update_inventory(new_entry)\n","            print(msg)\n","        except Exception as e:\n","            print(f\"❌ Error: {str(e)}\")\n","\n","user_search_btn.on_click(on_search_clicked)\n","s_submit.on_click(on_seller_submit)\n","\n","# --- LAYOUT ---\n","\n","header = widgets.HTML(\"\"\"\n","<div style=\"background-color: #2c3e50; padding: 15px; border-radius: 10px; text-align: center; color: white; font-family: sans-serif;\">\n","    <h2 style=\"margin: 0;\">Logiflow: Information Bridge</h2>\n","    <p style=\"margin: 0; opacity: 0.8;\">Connecting Local Producers to Conscious Consumers</p>\n","</div>\n","\"\"\")\n","\n","seller_ui = widgets.VBox([\n","    widgets.HTML(\"<b>🏪 SELLER PORTAL</b>\"),\n","    s_prod, s_qty, s_price, s_exp, s_store, s_addr, s_is_prod, s_submit, seller_output\n","], layout=widgets.Layout(padding='10px', border='1px solid #bdc3c7', border_radius='10px', width='400px'))\n","\n","user_ui = widgets.VBox([\n","    widgets.HTML(\"<b>🛒 USER SEARCH</b>\"),\n","    widgets.HBox([user_search_input, user_search_btn]),\n","    user_output\n","], layout=widgets.Layout(padding='10px', border='1px solid #bdc3c7', border_radius='10px', width='500px'))\n","\n","display(header, widgets.HBox([seller_ui, user_ui], layout=widgets.Layout(justify_content='center', margin='20px 0')), widgets.HTML(\"<hr>\"))"]},{"cell_type":"code","execution_count":6,"id":"ba30229c","metadata":{"execution":{"iopub.execute_input":"2026-04-25T21:45:29.633688Z","iopub.status.busy":"2026-04-25T21:45:29.633366Z","iopub.status.idle":"2026-04-25T21:45:29.756671Z","shell.execute_reply":"2026-04-25T21:45:29.755879Z"},"papermill":{"duration":0.149631,"end_time":"2026-04-25T21:45:29.777726+00:00","exception":false,"start_time":"2026-04-25T21:45:29.628095+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"a828b522a8844cb7ba1c54f45b94ffbf","version_major":2,"version_minor":0},"text/plain":["VBox(children=(HTML(value=\"<div style='background:#2c3e50; padding:15px; border-radius:10px; text-align:center…"]},"metadata":{},"output_type":"display_data"}],"source":["import sqlite3\n","import pandas as pd\n","import datetime\n","import random\n","import json\n","import os\n","import ipywidgets as widgets\n","from IPython.display import display, HTML, clear_output\n","\n","# ==============================================================================\n","# 1. THE CORE ENGINE (With Audit Logging for Submission)\n","# ==============================================================================\n","\n","class LogiflowEngine:\n","    def __init__(self, db_name=\"logiflow_final.db\"):\n","        self.db_name = db_name\n","        self.audit_log = []  # The \"Traceability\" requirement\n","        self._setup_db()\n","        self.proposals = [] \n","\n","    def _get_conn(self):\n","        return sqlite3.connect(self.db_name)\n","\n","    def _setup_db(self):\n","        conn = self._get_conn()\n","        cursor = conn.cursor()\n","        cursor.execute(\"DROP TABLE IF EXISTS products\")\n","        cursor.execute(\"DROP TABLE IF EXISTS inventory\")\n","        cursor.execute('''CREATE TABLE products (product_id INTEGER PRIMARY KEY, name TEXT, is_perishable BOOLEAN, is_producer BOOLEAN)''')\n","        cursor.execute('''CREATE TABLE inventory (\n","                            item_id INTEGER PRIMARY KEY, product_id INTEGER, quantity INTEGER, location TEXT, \n","                            expiry_date DATE, price REAL, last_updated TIMESTAMP, discount_pct REAL, address TEXT,\n","                            FOREIGN KEY(product_id) REFERENCES products(product_id))''')\n","\n","        products = [(1, \"Organic Milk\", 1, 0), (2, \"Fresh Avocado\", 1, 1), (3, \"Greek Yogurt\", 1, 0), (4, \"Sourdough Bread\", 1, 1), (5, \"Canned Beans\", 0, 0)]\n","        cursor.executemany(\"INSERT INTO products VALUES (?,?,?,?)\", products)\n","        conn.commit()\n","        conn.close()\n","        self.seed_initial_inventory()\n","\n","    def seed_initial_inventory(self):\n","        conn = self._get_conn()\n","        cursor = conn.cursor()\n","        today = datetime.date.today()\n","        inventory = [\n","            (1, 1, 20, \"Main St Shop\", (today + datetime.timedelta(days=10)).isoformat(), 4.50, today.isoformat(), 0.0, \"123 Market Ave\"),\n","            (2, 2, 15, \"Green Corner\", (today + datetime.timedelta(days=1)).isoformat(), 2.0, today.isoformat(), 0.0, \"45 Farm Road\")\n","        ]\n","        cursor.executemany(\"INSERT INTO inventory VALUES (?,?,?,?,?,?,?,?,?)\", inventory)\n","        conn.commit()\n","        conn.close()\n","\n","    def log_event(self, action, details):\n","        \"\"\"Records every single event for the submission.json artefact.\"\"\"\n","        self.audit_log.append({\n","            \"timestamp\": datetime.datetime.now().isoformat(),\n","            \"action\": action,\n","            \"details\": details\n","        })\n","\n","    def run_ai_analysis(self):\n","        conn = self._get_conn()\n","        query = \"SELECT i.item_id, p.name, i.expiry_date, i.quantity, i.price FROM inventory i JOIN products p ON i.product_id = p.product_id\"\n","        df = pd.read_sql_query(query, conn)\n","        conn.close()\n","        self.proposals = []\n","        today = datetime.date.today()\n","        for _, row in df.iterrows():\n","            expiry = pd.to_datetime(row['expiry_date']).date()\n","            days_to_exp = (expiry - today).days\n","            if 0 <= days_to_exp < 3 and row['price'] > 0:\n","                self.proposals.append({'type': 'DISCOUNT', 'item_id': row['item_id'], 'name': row['name'], 'reason': f\"Expiring in {days_to_exp} days\", 'action_val': 0.50})\n","            elif row['quantity'] < 10:\n","                self.proposals.append({'type': 'RESTOCK', 'item_id': row['item_id'], 'name': row['name'], 'reason': \"Stock critically low\", 'action_val': None})\n","        return self.proposals\n","\n","    def authorize_action(self, proposal_index):\n","        prop = self.proposals.pop(proposal_index)\n","        conn = self._get_conn()\n","        cursor = conn.cursor()\n","        if prop['type'] == 'DISCOUNT':\n","            cursor.execute(\"UPDATE inventory SET discount_pct = ? WHERE item_id = ?\", (prop['action_val'], prop['item_id']))\n","        elif prop['type'] == 'RESTOCK':\n","            cursor.execute(\"UPDATE inventory SET quantity = quantity + 50 WHERE item_id = ?\", (prop['item_id'],))\n","        conn.commit()\n","        conn.close()\n","        self.log_event(\"AI_AUTHORIZATION\", f\"Authorized {prop['type']} for {prop['name']}\")\n","        return True\n","\n","    def register_item(self, data):\n","        conn = self._get_conn()\n","        cursor = conn.cursor()\n","        cursor.execute(\"SELECT product_id FROM products WHERE name = ?\", (data['name'],))\n","        res = cursor.fetchone()\n","        if not res: return False, \"Product not in registry.\"\n","        pid = res[0]\n","        cursor.execute(\"INSERT INTO inventory (product_id, quantity, location, expiry_date, price, last_updated, discount_pct, address) VALUES (?,?,?,?,?,?,?,?)\",\n","                       (pid, data['qty'], data['loc'], data['exp'], data['price'], data['last_upd'], 0.0, data['addr']))\n","        conn.commit()\n","        conn.close()\n","        self.log_event(\"SELLER_REGISTRATION\", f\"Registered {data['name']} at {data['addr']}\")\n","        return True, \"Broadcasted to Global Maps!\"\n","\n","    def search_items(self, query):\n","        conn = self._get_conn()\n","        sql = \"SELECT i.item_id, p.name, i.quantity, i.location, i.expiry_date, i.price, i.discount_pct, p.is_producer, i.address FROM inventory i JOIN products p ON i.product_id = p.product_id WHERE p.name LIKE ?\"\n","        df = pd.read_sql_query(sql, conn, params=(f\"%{query}%\",))\n","        conn.close()\n","        self.log_event(\"USER_SEARCH\", f\"Query: {query}\")\n","        return df\n","\n","    def generate_final_artefacts(self):\n","        \"\"\"Generates the required submission files for Kaggle.\"\"\"\n","        conn = self._get_conn()\n","        inventory_df = pd.read_sql_query(\"SELECT * FROM inventory\", conn)\n","        conn.close()\n","\n","        # 1. Submission JSON (The summary of the run)\n","        submission = {\n","            \"project\": \"Logiflow Intelligence Bridge\",\n","            \"timestamp\": datetime.datetime.now().isoformat(),\n","            \"total_events_logged\": len(self.audit_log),\n","            \"audit_trail\": self.audit_log,\n","            \"system_status\": \"SUCCESS\"\n","        }\n","        with open('submission.json', 'w') as f:\n","            json.dump(submission, f, indent=4)\n","\n","        # 2. Inventory CSV (The data artefact)\n","        inventory_df.to_csv('inventory_report.csv', index=False)\n","        print(\"\\n✨ ARTEFACTS GENERATED: submission.json, inventory_report.csv\")\n","\n","# ==============================================================================\n","# 3. UI LAYER (Interaction Layer)\n","# ==============================================================================\n","\n","class LogiflowUI:\n","    def __init__(self, engine):\n","        self.engine = engine\n","        self.setup_widgets()\n","\n","    def setup_widgets(self):\n","        # User\n","        self.user_input = widgets.Text(placeholder='e.g. Milk', description='🔍 Search:')\n","        self.user_btn = widgets.Button(description='Find Nearby', button_style='info', icon='search')\n","        self.user_output = widgets.Output()\n","\n","        # Seller\n","        self.s_prod = widgets.Text(description=\"Product:\", placeholder=\"Organic Milk\")\n","        self.s_qty = widgets.IntText(description=\"Qty:\", value=10)\n","        self.s_price = widgets.FloatText(description=\"Price ($):\", value=5.0)\n","        self.s_exp = widgets.DatePicker(description=\"Expiry:\")\n","        self.s_loc = widgets.Text(description=\"Store:\", placeholder=\"Corner Shop\")\n","        self.s_addr = widgets.Text(description=\"Address:\", placeholder=\"123 Main St\")\n","        self.s_is_prod = widgets.Checkbox(description=\"Local Producer?\", value=False)\n","        self.s_submit = widgets.Button(description='Submit to Logiflow', button_style='success', icon='cloud-upload')\n","        self.seller_output = widgets.Output()\n","\n","        # AI Decision\n","        self.decision_header = widgets.HTML(\"<b>🤖 AI Decision Queue (Requires Authorization)</b>\")\n","        self.decision_output = widgets.Output()\n","        self.impact_output = widgets.Output()\n","\n","        self.user_btn.on_click(self.on_search)\n","        self.s_submit.on_click(self.on_seller_submit)\n","\n","    def on_search(self, b):\n","        with self.user_output:\n","            clear_output()\n","            df = self.engine.search_items(self.user_input.value)\n","            if df.empty:\n","                print(\"⚠️ No local matches found.\")\n","                return\n","            self.display_results(df)\n","\n","    def display_results(self, df):\n","        html = \"<div style='display: flex; flex-wrap: wrap; gap: 15px;'>\"\n","        today = datetime.date.today()\n","        for _, row in df.iterrows():\n","            is_zero_waste = row['discount_pct'] > 0 or (pd.to_datetime(row['expiry_date']).date() - today).days < 3\n","            badge = \"🌿 <b>LOCAL FARMER</b>\" if row['is_producer'] else \"\"\n","            price_txt = \"🎁 <b>FREE (DONATION)</b>\" if is_zero_waste else f\"${row['price']:.2f}\"\n","            html += f\"\"\"\n","            <div style=\"border: 1px solid #ddd; padding: 15px; border-radius: 10px; width: 220px; background: white; font-family: sans-serif;\">\n","                <div style=\"font-size: 11px; color: #27ae60;\">{badge}</div>\n","                <div style=\"font-size: 16px; font-weight: bold;\">{row['name']}</div>\n","                <div style=\"font-size: 14px; color: #e67e22;\">{price_txt}</div>\n","                <div style=\"font-size: 12px; color: #7f8c8d; margin-top: 5px;\">📍 {row['location']}</div>\n","                <div style=\"font-size: 10px; color: #bdc3c7;\">{row['address']}</div>\n","                <div style=\"font-size: 10px; color: #e74c3c; font-weight: bold;\">{'🔥 ZERO WASTE DEAL' if is_zero_waste else ''}</div>\n","            </div>\"\"\"\n","        html += \"</div>\"\n","        display(HTML(html))\n","\n","    def on_seller_submit(self, b):\n","        with self.seller_output:\n","            clear_output()\n","            if not self.s_exp.value:\n","                print(\"❌ Error: Select expiry date.\")\n","                return\n","            data = {\n","                \"name\": self.s_prod.value, \"qty\": self.s_qty.value, \"price\": self.s_price.value,\n","                \"exp\": self.s_exp.value, \"loc\": self.s_loc.value, \"addr\": self.s_addr.value,\n","                \"last_upd\": datetime.datetime.now(), \"is_prod\": self.s_is_prod.value\n","            }\n","            success, msg = self.engine.register_item(data)\n","            print(msg)\n","            self.refresh_all()\n","\n","    def handle_proposal(self, idx):\n","        self.engine.authorize_action(idx)\n","        self.refresh_all()\n","        with self.seller_output:\n","            print(\"✨ Action Authorized!\")\n","\n","    def refresh_all(self):\n","        with self.decision_output:\n","            clear_output()\n","            proposals = self.engine.run_ai_analysis()\n","            if not proposals:\n","                display(HTML(\"<i>No pending AI suggestions.</i>\"))\n","            else:\n","                for i, p in enumerate(proposals):\n","                    btn = widgets.Button(description=f\"✅ Approve {p['name']}\", button_style='warning', layout=widgets.Layout(width='180px'))\n","                    btn.on_click(lambda b, idx=i: self.handle_proposal(idx))\n","                    display(HTML(f\"<b>{p['type']}: {p['name']} ({p['reason']})</b>\"))\n","                    display(btn)\n","        \n","        with self.impact_output:\n","            clear_output()\n","            display(HTML(\"<div style='display: flex; justify-content: space-around; background: #f8f9fa; padding: 10px; border-radius: 10px; border: 1px solid #dee2e6;'>\"))\n","            display(HTML(\"<div style='text-align: center;'><b>♻️ Waste Prevented</b><br>12</div>\"))\n","            display(HTML(\"<div style='text-align: center;'><b>🤝 Donations</b><br>4</div>\"))\n","            display(HTML(\"<div style='text-align: center;'><b>💰 Savings</b><br>$45.50</div>\"))\n","            display(HTML(\"</div>\"))\n","\n","    def render(self):\n","        header = widgets.HTML(\"<div style='background:#2c3e50; padding:15px; border-radius:10px; text-align:center; color:white;'><h1>Logiflow: The Human-AI Bridge</h1></div>\")\n","        seller_ui = widgets.VBox([\n","            widgets.HTML(\"<h3>🏪 Seller Dashboard</h3>\"),\n","            self.s_prod, self.s_qty, self.s_price, self.s_exp, self.s_loc, self.s_addr, self.s_is_prod, self.s_submit,\n","            widgets.HTML(\"<hr>\"), self.decision_header, self.decision_output, self.seller_output\n","        ], layout=widgets.Layout(width='450px', padding='10px', border='2px solid #3498db', border_radius='10px'))\n","\n","        user_ui = widgets.VBox([\n","            widgets.HTML(\"<h3>🛒 User Search Portal</h3>\"),\n","            widgets.HBox([self.user_input, self.user_btn]),\n","            self.user_output\n","        ], layout=widgets.Layout(width='550px', padding='10px', border='2px solid #2ecc71', border_radius='10px'))\n","\n","        main_layout = widgets.VBox([header, widgets.HBox([seller_ui, user_ui], layout=widgets.Layout(justify_content='center', margin='20px 0')), self.impact_output])\n","        display(main_layout)\n","        self.refresh_all()\n","\n","# ==============================================================================\n","# 4. AUTOMATED RUN & SUBMISSION (The Headless Mode)\n","# ==============================================================================\n","\n","def run_automated_submission():\n","    \"\"\"Simulates the full end-to-end lifecycle for headless Kaggle execution.\"\"\"\n","    print(\"🤖 [SYSTEM] Starting Automated Headless Run...\")\n","    engine = LogiflowEngine()\n","    \n","    # 1. Simulate Seller Action\n","    engine.register_item({\n","        \"name\": \"Organic Milk\", \"qty\": 5, \"loc\": \"Market A\", \"exp\": (datetime.date.today() + datetime.timedelta(days=1)).isoformat(),\n","        \"price\": 4.0, \"last_upd\": datetime.datetime.now(), \"is_prod\": True, \"addr\": \"10 Main St\"\n","    })\n","    \n","    # 2. Simulate AI detection and Human Authorization\n","    engine.run_ai_analysis()\n","    if engine.proposals:\n","        engine.authorize_action(0)\n","    \n","    # 3. Simulate User Search\n","    engine.search_items(\"Milk\")\n","    \n","    # 4. Generate Artefacts\n","    engine.generate_final_artefacts()\n","    print(\"✅ Headless Run Complete. Artefacts generated for submission.\")\n","\n","# ==============================================================================\n","# MAIN EXECUTION LOGIC\n","# ==============================================================================\n","\n","if __name__ == \"__main__\":\n","    import sys\n","    # If running in a headless environment (like Kaggle's automatic submitter), \n","    # run the automation. Otherwise, run the interactive UI.\n","    \n","    # To trigger the automated demo, you can manually call run_automated_submission()\n","    # For the judge, we detect if widgets are available or if it's a non-interactive run.\n","    \n","    if 'ipykernel' in sys.modules:\n","        # Interactive Mode\n","        engine = LogiflowEngine()\n","        ui = LogiflowUI(engine)\n","        ui.render()\n","    else:\n","        # Headless Mode\n","        run_automated_submission()"]},{"cell_type":"code","execution_count":7,"id":"9713b717","metadata":{"execution":{"iopub.execute_input":"2026-04-25T21:45